create table age_classifier
(
  age_id number not null,
  age_bracket varchar2(100) not null,
  age_range_from number not null,
  age_range_to number not null,
  constraint age_pk primary key (age_id)
)
/
insert into age_classifier(age_id,age_bracket,age_range_from,age_range_to)values  (1, 'infant',0,6)
/
