CREATE TABLE invoice
(
    invoice_id      NUMBER GENERATED BY DEFAULT ON NULL AS IDENTITY
                    CONSTRAINT inv_pk PRIMARY KEY,
    invoice_date    DATE NOT NULL,
    invoice_amount  NUMBER NOT NULL,
    currency        VARCHAR2(3) NOT NULL
)
/
CREATE TABLE payment
(
    payment_id      NUMBER GENERATED BY DEFAULT ON NULL AS IDENTITY
                    CONSTRAINT pay_pk PRIMARY KEY,
    payment_date    DATE NOT NULL,
    payment_amount  NUMBER NOT NULL,
    currency        VARCHAR2(3) NOT NULL,
    invoice_id      NUMBER NOT NULL,

    CONSTRAINT pay_inv_fk
        FOREIGN KEY (invoice_id)
        REFERENCES invoice (invoice_id)
)
/
CREATE INDEX idx_pay_inv_fk
ON payment(invoice_id)
/
